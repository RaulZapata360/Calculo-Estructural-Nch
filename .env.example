# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE ESTRUCTURACALC v2.1
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES:
# 1. Copiar este archivo a: .env (sin el .example)
# 2. Completar los valores según tu configuración
# 3. El archivo .env será ignorado por git (.gitignore)
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# API CONFIGURATION (Claude/Anthropic)
# ─────────────────────────────────────────────────────────────────────────
# Obtener API key en: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-v1-YOUR_API_KEY_HERE
CLAUDE_API_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-opus-4-7

# ─────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
HOST=localhost

# ─────────────────────────────────────────────────────────────────────────
# DATABASE (si se usa en futuro)
# ─────────────────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=estructuraCalc
# DB_USER=estructuraCalc
# DB_PASSWORD=your_password_here

# ─────────────────────────────────────────────────────────────────────────
# CARACTERÍSTICAS HABILITADAS
# ─────────────────────────────────────────────────────────────────────────
ENABLE_CALCULATIONS=true
ENABLE_PDF_EXPORT=true
ENABLE_3D_VIEW=true
ENABLE_API_INTEGRATION=true

# ─────────────────────────────────────────────────────────────────────────
# DEBUG Y LOGGING
# ─────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=info
